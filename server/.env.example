# 라비린스 온라인 서버 환경변수

PORT=3000
NODE_ENV=development

# 공유 PostgreSQL (듀오 duo-db 와 동일 인스턴스). lab_ 테이블만 사용.
# 개발(로컬): localhost 로. 컨테이너: duo-db 호스트명.
DATABASE_URL=postgresql://duo:password@localhost:55433/duo

# 라비린스 자체 JWT 시크릿(라비린스가 토큰을 직접 발급·검증. 길고 무작위로).
JWT_SECRET=change-me-to-a-long-random-secret

# 소셜 로그인 검증용 ---------------------------------------------------------
# 구글: id_token 의 aud 로 허용할 클라이언트 ID(iOS/Android/Web) 콤마구분
GOOGLE_CLIENT_IDS=xxxxx.apps.googleusercontent.com,yyyyy.apps.googleusercontent.com
# 애플: identity token 의 aud(앱 번들 ID)
APPLE_BUNDLE_ID=com.jiny.labyrinthonline
# 카카오는 access token 을 카카오 API 로 조회하므로 서버 키 불필요.

# CORS 허용 오리진(콤마 구분). 미설정 시 * (개발용)
ALLOWED_ORIGINS=
